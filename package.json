{
  "name": "@haxbrasil/haxfootball-discord",
  "version": "0.1.0",
  "description": "Discord bot for the BFL community.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "main": "./dist/index.mjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsdown --config tsdown.config.ts",
    "start": "node dist/index.mjs",
    "commands:deploy": "tsx src/register-commands.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "i18n": "pnpm run i18n:extract && pnpm run i18n:compile",
    "lint": "biome lint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@discordjs/builders": "^1.14.1",
    "@haxbrasil/haxfootball-api-sdk": "github:haxbrasil/haxfootball-api-sdk",
    "@lingui/core": "^5.9.5",
    "discord.js": "^14.26.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@biomejs/biome": "^2.4.15",
    "@lingui/cli": "^5.9.5",
    "@lingui/macro": "^5.9.5",
    "@types/node": "^24.10.0",
    "babel-plugin-macros": "^3.1.0",
    "tsdown": "^0.16.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
